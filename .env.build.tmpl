# BEGIN Dynamic ENV


################################
##### SERVER CONFIGURATION #####
################################

# Age private key to use.
SERVER__AGE_PRIVKEY=

# Domain used to serve HTTP content (HTTP/Websockets).
SERVER__HTTP_DOMAIN=$HTTP_DOMAIN
# Domain used to serve raw TLS content (SSH over TLS).
SERVER__TLS_DOMAIN=$TLS_DOMAIN
# Domain used to serve DNS (SSH over DNS).
SERVER__DNS_DOMAIN=$DNS_DOMAIN

# HTTP address to bind to, port 0 => Random.
SERVER__HTTP_LISTEN_ADDR=:$HTTP_PORT
# HTTPS address to bind to, port 0 => Random.
SERVER__HTTPS_LISTEN_ADDR=:$HTTPS_PORT
# Remote address to bind to, port 0 => Random.
SERVER__SSHD_LISTEN_ADDR=:$SSHD_PORT
# Remote address to bind to, port 0 => Random.
SERVER__DNS_LISTEN_ADDR=:$DNS_PORT
# Remote address to bind to, port 0 => Random.
SERVER__QUIC_LISTEN_ADDR=:$QUIC_PORT

# Verbosity. Repeat to increase
SERVER__VERBOSITY=

# Enable TLS.
SERVER__TLS=true
# Path to TLS certificate key.
SERVER__TLS_KEY=
# Path to TLS certificate.
SERVER__TLS_CERT=
# Enable QUIC.
SERVER__QUIC=

# Enable DNS.
SERVER__DNS=
# Disable database usage.
SERVER__NO_DB=
# Database filename to use.
SERVER__DB_NAME=

# List of IP allowed to access the /manage/ endpoint.
SERVER__ALLOWED_IPS=
# Access token required to access the /manage/ endpoint.
SERVER__ACCESS_TOKEN=
# Access token required to access the /manage/ endpoint.
SERVER__ADMIN_TOKEN=

# HTTP Basic Auth used to access the binaries endpoint.
SERVER__BINARIES_BASICAUTH=
# Path where are stored binaries on the filesystem.
SERVER__BINARIES_PATH=

# Show version information
SERVER__VERSION=
# Generate configuration file based on the current options.
SERVER__GENERATE_CONFIG=
# Configuration file to use.
SERVER__CONFIG_FILE=


################################
##### AGENT CONFIGURATION  #####
################################
# Age public key associated to the server. The provided public key should match the server public key
AGENT__AGEPUBKEY=

# The control HTTP server to connect to.
AGENT__SERVER=https://$HTTP_DOMAIN
# The SSH server to connect to when using direct SSH connections.
AGENT__SSH_SERVER=$HTTP_DOMAIN:$SSHD_PORT
# The QUIC domain used to tunnel the traffic.
AGENT__QUIC_DOMAIN=TLS_DOMAIN:$SSHD_PORT
# The TLS server to connect to when using SSH over TLS connections.
AGENT__TLS_SERVER=$TLS_DOMAIN
# The DNS server to connect to when using SSH over DNS connections, the magic name 'system' will be replaced by the list of the system DNS servers.
AGENT__DNS_SERVER=
# The DNS domain used to tunnel the traffic.
AGENT__DNS_DOMAIN=$DNS_DOMAIN


AGENT__PRIVATE_PASSWORD=
# SSH password to access the agent. If no password is provided, a random password is automatically generated.
AGENT__SHARED_PASSWORD=
# Nice name to identify the agent. Defaults to 'user@hostname'
AGENT__NAME=

# Start the SSHD server.
AGENT__SSHD_ENABLED=
# Start the Socks proxy server.
AGENT__SOCKS_ENABLED=
# Start the HTTP proxy server.
AGENT__HTTP_PROXY_ENABLED=

# Use the provided proxy to connect the control server. If no proxy is provided, by default the agent will attempt to use the underlying proxy configured on the system
AGENT__PROXY=
# Username to use with the proxy
AGENT__PROXY_USERNAME=
# Password to use with the proxy
AGENT__PROXY_PASSWORD=
# Domain to use with the proxy
AGENT__PROXY_DOMAIN=

# Use the provided proxy to use within the socks proxy. If no proxy is provided, by default the agent will attempt to use the underlying proxy configured on the system
AGENT__SOCKS_CUSTOM_PROXY=
# Use the proxy of the underlying system if applicable for all requests going through the socks proxy.
AGENT__SOCKS_USE_SYSTEM_PROXY=
# Username to use with the socks http upstream proxy
AGENT__SOCKS_PROXY_USERNAME=
# Password to use with the socks http upstream proxy
AGENT__SOCKS_PROXY_PASSWORD=
# Domain to use with the socks http upstream proxy
AGENT__SOCKS_PROXY_DOMAIN=

# Use the provided proxy to use within the http proxy. If no proxy is provided, by default the agent will attempt to use the underlying proxy configured on the system
AGENT__HTTP_CUSTOM_PROXY=
# Username to use with the http upstream proxy
AGENT__HTTP_PROXY_USERNAME=
# Password to use with the http upstream proxy
AGENT__HTTP_PROXY_PASSWORD=
# Domain to use with the http upstream proxy
AGENT__HTTP_PROXY_DOMAIN=

# Do not use the system proxy.
AGENT__NO_PROXY=

# The remote SSH port to bind to on the server.  By default, the port is 0 meaning the port will be random on the server.
AGENT__RSSH_PORT=
# The remote SOCKS proxy port to bind to on the server,  By default, the port is 0 meaning the port will be random on the server.
AGENT__SOCKS_PORT=
# The remote HTTP proxy port to bind to on the server,  By default, the port is 0 meaning the port will be random on the server.
AGENT__HTTP_PORT=

# Keep the system awake (try to prevent from sleep and lock screen).
AGENT__KEEPAWAKE=
# Seconds between two keepalive messages in seconds, reduce this value if the connection drops (0 => no keepalive).
AGENT__KEEPALIVE=
# Verbosity of the logs. Repeat -v to increase
AGENT__VERBOSITY=

# Only working days.
AGENT__ONLY_WORKING_DAYS=
# Start time of working day in days.
AGENT__WORKING_DAY_START=
# End time of working day in days.
AGENT__WORKING_DAY_END=
# Timezone of working day.
AGENT__WORKING_DAY_TIMEZONE=

# Order the SSH tunnels connection attempts.
AGENT__RSSH_ORDER=
# Timeout in second to wait for the SSH tunnel to become available (independent for each protocol attempt), 0 means wait indefinitely.
AGENT__RSSH_TIMEOUT=

# Ports to forward to the server (REMOTE_PORT[:LOCAL_IP]:LOCAL_PORT). If REMOTE_PORT is 0, the port will be randomly chosen on the server
AGENT__REMOTE_PORT_FORWARDING=

# Max retries connection attempts before giving up
AGENT__MAX_RETRIES=

# Show version information
AGENT__VERSION=
# Generate configuration file based on the current options.
AGENT__GENERATE_CONFIG=
# Configuration file to use.
AGENT__CONFIG_FILE=

# Start the agent in the background.
AGENT__BACKGROUND=
# Start the agent in the background.
AGENT__HIDDEN_BACKGROUND=

# System command used to perform SSH over DNS when raw DNS queries are blocked. The provided command is responsible for performing the DNS query and returning the result as raw bytes.
#  Powershell example: "((Resolve-DnsName -Type TXT -Server 127.0.0.1 '%s')[0].Strings -join '' -replace 's+', '' -split '..' | ForEach-Object { [Convert]::ToByte($_,16) } )"
#  Linux example:"dig +short +unknownformat -t TXT '%s' @127.0.0.1 | head -n1 | cut -d ' ' -f3- | tr -d ' '  | xxd -r -p".
AGENT__CUSTOM_DNS_COMMAND=

# Number of days to stay alive. Afterward, the agent will kill itself. (0 to disable the killswitch)
AGENT__KILLSWITCH=


