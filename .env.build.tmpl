################################
##### SERVER CONFIGURATION #####
################################

# Age private key used by the server.
SERVER__AGE_PRIVKEY=

# Domains used to serve HTTP and WebSocket traffic.
SERVER__HTTP_DOMAIN=$HTTP_DOMAIN
# Domains used to serve raw TLS traffic (SSH over TLS).
SERVER__TLS_DOMAIN=$TLS_DOMAIN
# Domain used to serve DNS-based traffic (SSH over DNS).
SERVER__DNS_DOMAIN=$DNS_DOMAIN

# Address and port to bind for HTTP connections (port 0 = random).
SERVER__HTTP_LISTEN_ADDR=:$HTTP_PORT
# Address and port to bind for HTTPS connections (port 0 = random).
SERVER__HTTPS_LISTEN_ADDR=:$HTTPS_PORT
# Address and port to bind for SSH connections (port 0 = random).
SERVER__SSHD_LISTEN_ADDR=:$SSHD_PORT
# Address and port to bind for DNS connections (port 0 = random).
SERVER__DNS_LISTEN_ADDR=:$DNS_PORT
# Address and port to bind for QUIC connections (port 0 = random).
SERVER__QUIC_LISTEN_ADDR=:$QUIC_PORT

# Increase log verbosity. Repeat for more detail.
SERVER__VERBOSITY=
# Suppress all log output.
SERVER__QUIET=

# Enable TLS support.
SERVER__TLS=true
# Path to the TLS private key file.
SERVER__TLS_KEY=
# Path to the TLS certificate file.
SERVER__TLS_CERT=
# Enable QUIC protocol support.
SERVER__QUIC=

# Enable DNS server for SSH-over-DNS connections.
SERVER__DNS=
# Disable database usage.
SERVER__NO_DB=
# Path or filename of the database to use.
SERVER__DB_NAME=

# List of IP addresses allowed to access the /manage/ endpoint.
SERVER__ALLOWED_IPS=
# Access token required for the /manage/ API endpoint.
SERVER__ACCESS_TOKEN=
# Admin token required for the /admin/ API endpoint.
SERVER__ADMIN_TOKEN=

# HTTP Basic Auth credentials required to access the binaries endpoint.
SERVER__BINARIES_BASICAUTH=
# Filesystem path where agent binaries are stored.
SERVER__BINARIES_PATH=

# Show version information and exit.
SERVER__VERSION=
# Generate a configuration file from the current settings.
SERVER__GENERATE_CONFIG=
# Path to the configuration file to use.
SERVER__CONFIG_FILE=


################################
##### AGENT CONFIGURATION  #####
################################
# Age public key associated with the server. Must match the server’s public key.
AGENT__AGEPUBKEY=

# Control HTTP server to connect to.
AGENT__SERVER=https://$HTTP_DOMAIN
# SSH server used for direct SSH connections.
AGENT__SSH_SERVER=$HTTP_DOMAIN:$SSHD_PORT
# QUIC domain used to tunnel traffic.
AGENT__QUIC_DOMAIN=$TLS_DOMAIN:$QUIC_PORT
# TLS server used for SSH-over-TLS connections.
AGENT__TLS_SERVER=$TLS_DOMAIN
# DNS servers used for SSH-over-DNS connections. Use 'system' to include the system DNS servers.
AGENT__DNS_SERVER=
# DNS domain used to tunnel SSH-over-DNS traffic.
AGENT__DNS_DOMAIN=$DNS_DOMAIN


AGENT__PRIVATE_PASSWORD=
# Password for local SSH access. If empty, a random password is generated automatically.
AGENT__SHARED_PASSWORD=
# Disable the local password generation if no static password is provided.
AGENT__DISABLE_PASSWORD=
# Friendly name to identify the agent (default: 'user@hostname').
AGENT__NAME=

# Enable the SSHD service.
AGENT__SSHD_ENABLED=
# Enable the SOCKS proxy service.
AGENT__SOCKS_ENABLED=
# Enable the HTTP proxy service.
AGENT__HTTP_PROXY_ENABLED=
# Enable the WireGuard service.
AGENT__WG_ENABLED=

# Proxy URL to use for control server connections. If omitted, the system proxy is used (if configured).
AGENT__PROXY=
# Username for the proxy server.
AGENT__PROXY_USERNAME=
# Password for the proxy server.
AGENT__PROXY_PASSWORD=
# Authentication domain for the proxy server.
AGENT__PROXY_DOMAIN=

# Custom proxy used within the SOCKS proxy. Falls back to the system proxy if not set.
AGENT__SOCKS_CUSTOM_PROXY=
# Use the system proxy for all SOCKS proxy traffic.
AGENT__SOCKS_USE_SYSTEM_PROXY=
# Username for the SOCKS upstream proxy.
AGENT__SOCKS_PROXY_USERNAME=
# Password for the SOCKS upstream proxy.
AGENT__SOCKS_PROXY_PASSWORD=
# Domain for the SOCKS upstream proxy.
AGENT__SOCKS_PROXY_DOMAIN=

# Custom proxy used within the HTTP proxy. Falls back to the system proxy if not set.
AGENT__HTTP_CUSTOM_PROXY=
# Username for the HTTP upstream proxy.
AGENT__HTTP_PROXY_USERNAME=
# Password for the HTTP upstream proxy.
AGENT__HTTP_PROXY_PASSWORD=
# Domain for the HTTP upstream proxy.
AGENT__HTTP_PROXY_DOMAIN=

# Ignore system proxy settings.
AGENT__NO_PROXY=

# Remote SSH port to bind on the server (0 = random).
AGENT__RSSH_PORT=
# Remote SOCKS proxy port to bind on the server (0 = random).
AGENT__SOCKS_PORT=
# Remote HTTP proxy port to bind on the server (0 = random).
AGENT__HTTP_PORT=
# Remote WireGuard port to bind on the server (0 = random).
AGENT__WG_PORT=

# Prevent the system from sleeping or locking.
AGENT__KEEPAWAKE=
# Interval in seconds between keepalive messages (0 = disabled).
AGENT__KEEPALIVE=
# Increase log verbosity. Repeat for more detail.
AGENT__VERBOSITY=
# Suppress all log output.
AGENT__QUIET=

# Restrict agent activity to working days only.
AGENT__ONLY_WORKING_DAYS=
# Start time of the working day (e.g. '09:00').
AGENT__WORKING_DAY_START=
# End time of the working day (e.g. '17:00').
AGENT__WORKING_DAY_END=
# Timezone used for working day calculations.
AGENT__WORKING_DAY_TIMEZONE=

# Preferred order of SSH tunnel protocols.
AGENT__RSSH_ORDER=
# Timeout in seconds to wait for each SSH tunnel attempt (0 = unlimited).
AGENT__RSSH_TIMEOUT=

# Ports to forward to the server (REMOTE_PORT[:LOCAL_IP]:LOCAL_PORT). Use 0 for a random remote port.
AGENT__REMOTE_PORT_FORWARDING=

# Maximum number of connection retries before giving up.
AGENT__MAX_RETRIES=

# Show version information and exit.
AGENT__VERSION=
# Generate a configuration file from the current settings.
AGENT__GENERATE_CONFIG=
# Path to the configuration file to use.
AGENT__CONFIG_FILE=

# Run the agent in the background.
AGENT__BACKGROUND=
# Run the agent in hidden background mode.
AGENT__HIDDEN_BACKGROUND=

# System command used to perform SSH over DNS when raw DNS queries are blocked. The provided command is responsible for performing the DNS query and returning the result as raw bytes.
#  Powershell example: "((Resolve-DnsName -Type TXT -Server 127.0.0.1 '%s')[0].Strings -join '' -replace 's+', '' -split '..' | ForEach-Object { [Convert]::ToByte($_,16) } )"
#  Linux example:"dig +short +unknownformat -t TXT '%s' @127.0.0.1 | head -n1 | cut -d ' ' -f3- | tr -d ' '  | xxd -r -p".
AGENT__CUSTOM_DNS_COMMAND=

# Number of days before the agent self-terminates (0 = disabled).
AGENT__KILLSWITCH=


